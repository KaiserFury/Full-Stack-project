<% layout('layouts/boilerplate') -%>

    <body>
        <p class="h1 show-title mt-3 mb-4">
            <%= listing.title %>
        </p>

        <div class="row align-items-start">
            <div class="col-md-5">
                <div class="img-box">
                    <img src="<%= listing.image %>" alt="listing_image"
                        style=" width: 100%; height: 25rem; object-fit: contain;" class="card-img-top">
                </div>
            </div>
            <div class="col-md-7">
                <ul class="list-unstyled">

                    <li>
                        <b>Description: </b>
                        <%= listing.description %>
                    </li>
                    <li>
                        <b>Price: </b>&#8377;<%= listing.price.toLocaleString("en-IN") %>
                    </li>
                    <li>
                        <b>Location: </b>
                        <%= listing.location %>
                    </li>
                    <li>
                        <b>Country: </b>
                        <%= listing.country %>
                    </li>
                    <li>
                        <b>Rating: </b>

                    </li>
                </ul>


                <a href="<%=listing._id%>/edit" class="btn btn-danger">Edit details</a>
                <a href="<%=listing._id%>/delete" class="btn btn-danger m-2">Delete listing</a>
                <div>
                    <hr class="border border-danger border-2 opacity-50">
                    <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation">
                        <p class="h5 fw-bold">Leave Review</p>
                        <label for="rating" class="form-label ">Rating</label>
                        <input type="range" class="form-range " min="0" max="5" id="rating" name="reviews[rating]">
                        <label for="comment" class="form-label">Comment</label>
                        <div class="input-group mb-3">
                            <textarea class="form-control border border-danger " id="comment" rows="2"
                                name="reviews[comment]" required></textarea>
                            <span class="input-group-text">
                                <button type="submit" class="btn btn--secondary">Submit Review</button>
                            </span>
                        </div>
                    </form>
                </div>

            </div>

            <hr class="border border-secondary border-2 opacity-50">
            <p class="h4 fw-bold">Reviews</p>
            <div class="row">
                <%for(let opition of listing.reviews) {%>
                    <div class="card ms-1 mb-2 col-3" style="width: 20rem;">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title">Unknown</h5>
                                <h6 class="card-subtitle mb-2 text-body-secondary">
                                    <%= opition.rating %> Stars
                                </h6>
                                <p class="card-text">
                                    <%= opition.comment%>
                                </p>
                            </div>

                            <form class="mt-3" action="/listings/<%= listing._id%>/reviews/<%= opition._id%>?_method=DELETE" method="POST">
                                <button class="btn btn-danger mb-1">Delete Reviews</button>
                            </form>
                        </div>
                    </div>
                    <%}%>
            </div>
        </div>
    </body>