<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <h1>Welcome</h1>
    <!-- Navigate to new listing form -->
    <form action="/listings/new" method="get">
        <button>Create New Listing</button>
    </form>
    <ul> 
        <!-- Dynamic list: Loop through all listings and create links using their MongoDB ObjectID -->
        <%for(list of allListing){%>
            <li>
                <a href="/listings/<%= list._id %>"> 
                    <%= list.title %> 
                </a>
            </li>
        <%}%>
    </ul>
</body>
</html>