<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <h3>Edit Your Listing</h3>
    <form action="/listings/<%=listing._id%>?_method=PUT" method="post">
        <input type="text" name="listing[title]" placeholder="enter title" value="<%=listing.title%>">
    </br> </br>
        <textarea name="listing[description]" placeholder="enter description" cols="30" rows="5"><%=listing.description%></textarea>
    </br> </br>
        <input  name= "listing[image]" placeholder="enter image URL/LINK" value="<%=listing.image%>">
    </br> </br>
        <input type="number" name="listing[price]" placeholder="enter price" value="<%=listing.price%>">
    </br> </br>
        <input type="text" name="listing[location]" placeholder="enter location" value="<%=listing.location%>">
    </br> </br>
        <input type="text" name="listing[country]" placeholder="enter country" value="<%=listing.country%>">
    </br> </br>
        <button>Save</button>
    </form>
</body>
</html>